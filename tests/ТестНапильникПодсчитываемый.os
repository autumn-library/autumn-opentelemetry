#Использовать "."

Перем Поделка;

&ТестовыйНабор(Характер = "Одиночка")
Процедура ПриСозданииОбъекта() Экспорт
КонецПроцедуры

&ПередКаждым
Процедура ПередКаждым() Экспорт
	Поделка = Новый Поделка();
	Поделка.ЗапуститьПриложение();
КонецПроцедуры

&Тест
Процедура НапильникПодсчитываемый_МетодВыполняетсяБезОшибок() Экспорт

	// Когда
	Служба = Поделка.НайтиЖелудь("ПодсчитываемаяСлужба");
	Результат = Служба.ОбработатьЗапрос();

	// Тогда - метод завершился без ошибок, счётчик инкрементирован
	Ожидаем.Что(Результат).Равно(Истина);

КонецПроцедуры

&Тест
Процедура НапильникПодсчитываемый_МетодВызываетсяНесколькоРаз() Экспорт

	// Дано
	Служба = Поделка.НайтиЖелудь("ПодсчитываемаяСлужба");

	// Когда - несколько вызовов подряд
	Служба.ОбработатьЗапрос();
	Служба.ОбработатьЗапрос();
	Служба.ОбработатьЗапрос();

	// Тогда - все вызовы завершились без ошибок
	Ожидаем.Что(Истина).Равно(Истина);

КонецПроцедуры
