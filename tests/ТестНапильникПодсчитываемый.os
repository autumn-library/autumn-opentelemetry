#Использовать autumn
#Использовать asserts
#Использовать opentelemetry
#Использовать ".."
#Использовать "."

Перем Поделка;

&ТестовыйНабор(Характер = "Одиночка")
Процедура ПриСозданииОбъекта() Экспорт
КонецПроцедуры

&ПередКаждым
Процедура ПередКаждым() Экспорт
	НастройкиОтел = Новый Соответствие();
	НастройкиОтел.Вставить("enabled", Истина);
	ЗначенияДеталек = Новый Соответствие();
	ЗначенияДеталек.Вставить("otel", НастройкиОтел);
	Совет = Новый СоветДругогоМастера();
	Совет.ЗначенияДеталек(ЗначенияДеталек);
	Поделка = Новый Поделка(Совет);
	Поделка.ЗапуститьПриложение();
КонецПроцедуры

&Тест
Процедура НапильникПодсчитываемый_МетодВыполняетсяБезОшибок() Экспорт

	// Когда
	Служба = Поделка.НайтиЖелудь("ПодсчитываемаяСлужба");
	Результат = Служба.ОбработатьЗапрос();

	// Тогда - метод завершился без ошибок, счётчик инкрементирован
	Ожидаем.Что(Результат).Равно(Истина);

КонецПроцедуры

&Тест
Процедура НапильникПодсчитываемый_МетодВызываетсяНесколькоРаз() Экспорт

	// Дано
	Служба = Поделка.НайтиЖелудь("ПодсчитываемаяСлужба");

	// Когда - несколько вызовов подряд
	Служба.ОбработатьЗапрос();
	Служба.ОбработатьЗапрос();
	Служба.ОбработатьЗапрос();

	// Тогда - все вызовы завершились без ошибок
	Ожидаем.Что(Истина).Равно(Истина);

КонецПроцедуры

&Тест
Процедура НапильникПодсчитываемый_МетодУровняМетода_ВыполняетсяБезОшибок() Экспорт

	// Когда
	Служба = Поделка.НайтиЖелудь("ПодсчитываемаяСлужбаМетод");
	Результат = Служба.ПодсчитываемыйМетод();

	// Тогда
	Ожидаем.Что(Результат).Равно("подсчитано");

КонецПроцедуры

&Тест
Процедура НапильникПодсчитываемый_МетодСЯвнымИменемМетрики_ВыполняетсяБезОшибок() Экспорт

	// Когда
	Служба = Поделка.НайтиЖелудь("ПодсчитываемаяСлужбаМетод");
	Результат = Служба.МетодСЯвнымИменем();

	// Тогда
	Ожидаем.Что(Результат).Равно("явное-имя");

КонецПроцедуры

&Тест
Процедура НапильникПодсчитываемый_ПриОтелОтключен_МетодВыполняетсяБезОборачивания() Экспорт

// Дано - otel.enabled не задан (по умолчанию Ложь)
ПустойСовет = Новый СоветДругогоМастера();
ПоделкаБезОтел = Новый Поделка(ПустойСовет);
ПоделкаБезОтел.ЗапуститьПриложение();

// Когда
Служба = ПоделкаБезОтел.НайтиЖелудь("ПодсчитываемаяСлужба");
Результат = Служба.ОбработатьЗапрос();

// Тогда - метод работает, бин не обёрнут декоратором → SDK не инициализировался
Ожидаем.Что(Результат).Равно(Истина);
Ожидаем.Что(Строка(ТипЗнч(Служба))).Равно("ПодсчитываемаяСлужба");

КонецПроцедуры
