#Использовать "."

Перем Поделка;

&ТестовыйНабор(Характер = "Одиночка")
Процедура ПриСозданииОбъекта() Экспорт
КонецПроцедуры

&ПередКаждым
Процедура ПередКаждым() Экспорт
	Поделка = Новый Поделка();
	Поделка.ЗапуститьПриложение();
КонецПроцедуры

&Тест
Процедура НапильникЗамеряемый_МетодВыполняетсяБезОшибок() Экспорт

	// Когда
	Служба = Поделка.НайтиЖелудь("ЗамеряемаяСлужба");
	Результат = Служба.ВыполнитьДолгуюОперацию();

	// Тогда - метод завершился без ошибок, длительность записана в гистограмму
	Ожидаем.Что(Результат).Равно("готово");

КонецПроцедуры

&Тест
Процедура НапильникЗамеряемый_МетодВызываетсяНесколькоРаз() Экспорт

	// Дано
	Служба = Поделка.НайтиЖелудь("ЗамеряемаяСлужба");

	// Когда - несколько вызовов подряд
	Служба.ВыполнитьДолгуюОперацию();
	Служба.ВыполнитьДолгуюОперацию();
	Служба.ВыполнитьДолгуюОперацию();

	// Тогда - все вызовы завершились без ошибок
	Ожидаем.Что(Истина).Равно(Истина);

КонецПроцедуры
