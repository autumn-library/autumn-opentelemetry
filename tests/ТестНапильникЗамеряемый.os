#Использовать "."

Перем Поделка;

&ТестовыйНабор(Характер = "Одиночка")
Процедура ПриСозданииОбъекта() Экспорт
КонецПроцедуры

&ПередКаждым
Процедура ПередКаждым() Экспорт
	НастройкиОтел = Новый Соответствие();
	НастройкиОтел.Вставить("enabled", Истина);
	ЗначенияДеталек = Новый Соответствие();
	ЗначенияДеталек.Вставить("otel", НастройкиОтел);
	Совет = Новый СоветДругогоМастера();
	Совет.ЗначенияДеталек(ЗначенияДеталек);
	Поделка = Новый Поделка(Совет);
	Поделка.ЗапуститьПриложение();
КонецПроцедуры

&Тест
Процедура НапильникЗамеряемый_МетодВыполняетсяБезОшибок() Экспорт

	// Когда
	Служба = Поделка.НайтиЖелудь("ЗамеряемаяСлужба");
	Результат = Служба.ВыполнитьДолгуюОперацию();

	// Тогда - метод завершился без ошибок, длительность записана в гистограмму
	Ожидаем.Что(Результат).Равно("готово");

КонецПроцедуры

&Тест
Процедура НапильникЗамеряемый_МетодВызываетсяНесколькоРаз() Экспорт

	// Дано
	Служба = Поделка.НайтиЖелудь("ЗамеряемаяСлужба");

	// Когда - несколько вызовов подряд
	Служба.ВыполнитьДолгуюОперацию();
	Служба.ВыполнитьДолгуюОперацию();
	Служба.ВыполнитьДолгуюОперацию();

	// Тогда - все вызовы завершились без ошибок
	Ожидаем.Что(Истина).Равно(Истина);

КонецПроцедуры

&Тест
Процедура НапильникЗамеряемый_МетодУровняМетода_ВыполняетсяБезОшибок() Экспорт

	// Когда
	Служба = Поделка.НайтиЖелудь("ЗамеряемаяСлужбаМетод");
	Результат = Служба.ЗамеряемыйМетод();

	// Тогда
	Ожидаем.Что(Результат).Равно("замерено");

КонецПроцедуры

&Тест
Процедура НапильникЗамеряемый_МетодСЯвнымИменемМетрики_ВыполняетсяБезОшибок() Экспорт

	// Когда
	Служба = Поделка.НайтиЖелудь("ЗамеряемаяСлужбаМетод");
	Результат = Служба.МетодСЯвнымИменем();

	// Тогда
	Ожидаем.Что(Результат).Равно("явное-имя");

КонецПроцедуры

&Тест
Процедура НапильникЗамеряемый_ПриОтелОтключен_МетодВыполняетсяБезОборачивания() Экспорт

// Дано - otel.enabled не задан (по умолчанию Ложь)
ПустойСовет = Новый СоветДругогоМастера();
ПоделкаБезОтел = Новый Поделка(ПустойСовет);
ПоделкаБезОтел.ЗапуститьПриложение();

// Когда
Служба = ПоделкаБезОтел.НайтиЖелудь("ЗамеряемаяСлужба");
Результат = Служба.ВыполнитьДолгуюОперацию();

// Тогда - метод работает, бин не обёрнут декоратором → SDK не инициализировался
Ожидаем.Что(Результат).Равно("готово");
Ожидаем.Что(Строка(ТипЗнч(Служба))).Равно("ЗамеряемаяСлужба");

КонецПроцедуры
