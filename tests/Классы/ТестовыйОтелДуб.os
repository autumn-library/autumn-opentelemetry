#Использовать opentelemetry

// Тестовый Дуб - предоставляет beans OpenTelemetry SDK с in-memory провайдерами
// для изолированного тестирования напильников без внешних зависимостей.
// Аннотация &Верховный позволяет переопределить одноимённые бины из ОтелДуб.

&Дуб
&Спецификация("Инициализация")
Процедура ПриСозданииОбъекта()
КонецПроцедуры

&Завязь
&Верховный
&Спецификация("Инициализация")
Функция ОтелSdk() Экспорт
	ПровайдерТрассировки = Новый ОтелПровайдерТрассировки(Новый ОтелРесурс(Истина));
	ПровайдерМетрик = Новый ОтелПровайдерМетрик();
	Возврат Новый ОтелПостроительSdk()
		.УстановитьПровайдерТрассировки(ПровайдерТрассировки)
		.УстановитьПровайдерМетрик(ПровайдерМетрик)
		.Построить();
КонецФункции

&Завязь
&Верховный
&Спецификация("Инициализация")
Функция ОтелТрассировщик(&Пластилин Поделка) Экспорт
	ОтелSdkЭкземпляр = Поделка.НайтиЖелудь("ОтелSdk");
	Возврат ОтелSdkЭкземпляр.ПолучитьТрассировщик("autumn-test");
КонецФункции

&Завязь
&Верховный
&Спецификация("Инициализация")
Функция ОтелМетр(&Пластилин Поделка) Экспорт
	ОтелSdkЭкземпляр = Поделка.НайтиЖелудь("ОтелSdk");
	Возврат ОтелSdkЭкземпляр.ПолучитьМетр("autumn-test");
КонецФункции
