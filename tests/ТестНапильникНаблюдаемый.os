// BSLLS:MissingReturnedValueDescription-off
#Использовать autumn
#Использовать asserts
#Использовать opentelemetry
#Использовать ".."
#Использовать "."

Перем Поделка;

&ТестовыйНабор(Характер = "Одиночка")
Процедура ПриСозданииОбъекта() Экспорт
КонецПроцедуры

&ПередКаждым
Процедура ПередКаждым() Экспорт
	ОтелКонтекст.Очистить();
	НастройкиОтел = Новый Соответствие();
	НастройкиОтел.Вставить("enabled", Истина);
	ЗначенияДеталек = Новый Соответствие();
	ЗначенияДеталек.Вставить("otel", НастройкиОтел);
	Совет = Новый СоветДругогоМастера();
	Совет.ЗначенияДеталек(ЗначенияДеталек);
	Поделка = Новый Поделка(Совет);
	Поделка.ЗапуститьПриложение();
КонецПроцедуры

&ПослеКаждого
Процедура ПослеКаждого() Экспорт
	ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура НапильникНаблюдаемый_МетодВыполняетсяБезОшибок() Экспорт

	// Когда
	Служба = Поделка.НайтиЖелудь("НаблюдаемаяСлужба");
	Результат = Служба.ВыполнитьОперацию("тест");

	// Тогда
	Ожидаем.Что(Результат).Равно("тест_выполнено");

КонецПроцедуры

&Тест
Процедура НапильникНаблюдаемый_МетодУровняМетода_ВыполняетсяБезОшибок() Экспорт

	// Когда
	Служба = Поделка.НайтиЖелудь("НаблюдаемаяСлужбаМетод");
	Результат = Служба.НаблюдаемыйМетод();

	// Тогда
	Ожидаем.Что(Результат).Равно("наблюдаемый");

КонецПроцедуры

&Тест
Процедура НапильникНаблюдаемый_МетодСВидомСпана_ВыполняетсяБезОшибок() Экспорт

	// Когда
	Служба = Поделка.НайтиЖелудь("НаблюдаемаяСлужбаМетод");
	Результат = Служба.МетодСервер();

	// Тогда
	Ожидаем.Что(Результат).Равно("сервер");

КонецПроцедуры

&Тест
Процедура НапильникНаблюдаемый_МетодСАтрибутомПараметра_ВыполняетсяБезОшибок() Экспорт

	// Когда
	Служба = Поделка.НайтиЖелудь("НаблюдаемаяСлужбаМетод");
	Результат = Служба.МетодСАтрибутом("ORD-1", "USR-7");

	// Тогда
	Ожидаем.Что(Результат).Равно("ORD-1/USR-7");

КонецПроцедуры

&Тест
Процедура НапильникНаблюдаемый_МетодСОшибкой_ПрокидываетИсключение() Экспорт

	// Когда
	Служба = Поделка.НайтиЖелудь("НаблюдаемаяСлужбаМетод");
	БылоИсключение = Ложь;
	Попытка
		Служба.МетодСОшибкой();
	Исключение
		БылоИсключение = Истина;
	КонецПопытки;

	// Тогда
	Ожидаем.Что(БылоИсключение).Равно(Истина);

КонецПроцедуры

&Тест
Процедура НапильникНаблюдаемый_ПриОтелОтключен_МетодВыполняетсяБезОборачивания() Экспорт

	// Дано - otel.enabled не задан (по умолчанию Ложь)
	ПустойСовет = Новый СоветДругогоМастера();
	ПоделкаБезОтел = Новый Поделка(ПустойСовет);
	ПоделкаБезОтел.ЗапуститьПриложение();

	// Когда
	Служба = ПоделкаБезОтел.НайтиЖелудь("НаблюдаемаяСлужба");
	Результат = Служба.ВыполнитьОперацию("тест");

	// Тогда - метод работает, напильник не применился
	Ожидаем.Что(Результат).Равно("тест_выполнено");

КонецПроцедуры
